void selectionSort(int[] array, int tamanho) {
	for (int i = 0; i < (tamanho - 1); i++) {
        	int menor = i;
         	for (int j = (i + 1); j < tamanho; j++) {
            		if (array[menor] > array[j]) {
               			menor = j;
            		}
         	}
      		int temp = array[i];
      		array[i] = array[menor];
      		array[menor] = temp;
      	}
}
